# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Kalshi — prod "elections" cluster hosts the BTC/ETH crypto markets.
KALSHI_API_KEY=your-kalshi-access-key-id
KALSHI_ENV=prod
# RSA private key (PEM). Inline; the loader normalizes \n-escapes / real newlines.
KALSHI_API_SECRET="-----BEGIN RSA PRIVATE KEY-----
...your PEM here...
-----END RSA PRIVATE KEY-----"

# Binance market data is PUBLIC (no key needed for 1s klines). Optional.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
